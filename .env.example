# ---------------------------------------------------------------------------
# TTS Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ---------------------------------------------------------------------------

# AWS Credentials (IAM user: tts-pipeline-local)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=eu-central-1         # adjust to your region

# S3
S3_BUCKET=your_bucket_name

# EC2 Training
AMI_ID=your_custom_ami_id               # custom TTS AMI snapshot
INSTANCE_TYPE=g4dn.xlarge              # Tesla T4, 16GB VRAM
SUBNET_ID=your_subnet_id               # any public subnet in your region
SECURITY_GROUP_ID=your_security_group_id
INSTANCE_PROFILE_ARN=arn:aws:iam::your_account_id:instance-profile/profile_name
SPOT_MAX_PRICE=0.30                    # max spot price in USD/hr

# Notifications (SNS)
SNS_TOPIC_ARN=arn:aws:sns:your-region:your_account_id:notifications_topic

# Monitoring (CloudWatch)
CLOUDWATCH_LOG_GROUP=/tts/yout_monitoring_group

# GitHub
GITHUB_REPO=your_github_repo
